        "    terminated = False\n",
        "    \n",
        "    while not terminated:\n",
        "        if np.random.random() < epsilon:\n",
        "            action = env_deterministic.action_space.sample()\n",
        "        else:\n",
        "            action = np.argmax(Q_determ[state, :])\n",
        "        \n",
        "        next_state, reward, terminated, truncated, info = env_deterministic.step(action)\n",
        "        ep_reward += reward\n",
        "        Q_determ[state, action] += alpha * (reward + gamma * np.max(Q_determ[next_state, :]) - Q_determ[state, action])\n",
        "        state = next_state\n",
        "        ep_length += 1\n",
        "    \n",
        "    rewards_determ.append(ep_reward)\n",
        "    lengths_determ.append(ep_length)\n",
        "    epsilon = max(0.01, epsilon * 0.995)\n",
        "    \n",
        "    if (ep + 1) % 100 == 0:\n",
        "        print(f\"  Episodio {ep+1:3d}: Recompensa promedio = {np.mean(rewards_determ[-50:]):.3f}\")\n",
        "\nprint(\"✓ Entrenamiento determinístico completado\")"
      ],
