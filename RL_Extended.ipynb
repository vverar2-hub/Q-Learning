        "def train_with_params(env, episodes=300, alpha=0.1, gamma=0.99, epsilon_start=1.0, epsilon_end=0.01, epsilon_decay=0.995):\n",
        "    \"\"\"\n",
        "    Entrena con parámetros específicos y retorna métricas\n",
        "    \"\"\"\n",
        "    Q = np.zeros((env.observation_space.n, env.action_space.n))\n",
        "    rewards = []\n",
        "    epsilon = epsilon_start\n",
        "    \n",
        "    for episode in range(episodes):\n",
        "        state, _ = env.reset()\n",
        "        episode_reward = 0\n",
        "        terminated = False\n",
        "        \n",
        "        while not terminated:\n",
        "            if np.random.random() < epsilon:\n",
        "                action = env.action_space.sample()\n",
        "            else:\n",
        "                action = np.argmax(Q[state, :])\n",
        "            \n",
        "            next_state, reward, terminated, truncated, info = env.step(action)\n",
        "            episode_reward += reward\n",
        "            Q[state, action] += alpha * (reward + gamma * np.max(Q[next_state, :]) - Q[state, action])\n",
        "            state = next_state\n",
        "        \n",
        "        rewards.append(episode_reward)\n",
        "        epsilon = max(epsilon_end, epsilon * epsilon_decay)\n",
        "    \n",
        "    return rewards\n",
        "\nprint(\"Analizando impacto de ALPHA (Learning Rate)...\\n\")\n",
        "env = gym.make(\"FrozenLake-v1\")\n",
        "alphas = [0.01, 0.05, 0.1, 0.2, 0.5]\n",
        "results_alpha = {}\n",
        "\n",
        "for alpha in alphas:\n",
        "    rewards = train_with_params(env, episodes=300, alpha=alpha)\n",
        "    results_alpha[alpha] = rewards\n",
        "    final_avg = np.mean(rewards[-50:])\n",
        "    print(f\"Alpha = {alpha:4.2f}: Recompensa final = {final_avg:.3f}\")\n",
        "\nprint(\"✓ Análisis de Alpha completado\")"
