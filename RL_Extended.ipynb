      "source": [
        "# 5. POLÍTICAS DE EXPLORACIÓN: UCB Y THOMPSON SAMPLING"
      ],
      "metadata": {
        "id": "section_policies"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def ucb_q_learning(env, episodes=500, alpha=0.1, gamma=0.99, c=2.0):\n",
        "    \"\"\"\n",
        "    Upper Confidence Bound (UCB) Policy\n",
        "    Favorece acciones no exploradas o con buena media\n",
        "    \"\"\"\n",
        "    Q = np.zeros((env.observation_space.n, env.action_space.n))\n",
        "    N = np.zeros((env.observation_space.n, env.action_space.n))  # Contador de visitas\n",
        "    rewards_per_episode = []\n",
        "    episode_lengths = []\n",
        "    \n",
        "    for episode in range(episodes):\n",
        "        state, _ = env.reset()\n",
        "        episode_reward = 0\n",
        "        steps = 0\n",
        "        terminated = False\n",
        "        \n",
        "        while not terminated:\n",
        "            # UCB Selection\n",
        "            total_visits = np.sum(N[state, :])\n",
        "            ucb_values = np.zeros(env.action_space.n)\n",
        "            \n",
        "            for a in range(env.action_space.n):\n",
        "                if N[state, a] == 0:\n",
        "                    ucb_values[a] = float('inf')\n",
        "                else:\n",
        "                    ucb_values[a] = Q[state, a] + c * np.sqrt(np.log(total_visits + 1) / N[state, a])\n",
        "            \n",
        "            action = np.argmax(ucb_values)\n",
        "            \n",
        "            # Ejecutar acción\n",
        "            next_state, reward, terminated, truncated, info = env.step(action)\n",
        "            episode_reward += reward\n",
        "            \n",
        "            # Actualizar Q y contador\n",
        "            N[state, action] += 1\n",
        "            Q[state, action] += alpha * (reward + gamma * np.max(Q[next_state, :]) - Q[state, action])\n",
        "            \n",
        "            state = next_state\n",
        "            steps += 1\n",
        "        \n",
        "        rewards_per_episode.append(episode_reward)\n",
        "        episode_lengths.append(steps)\n",
        "        \n",
        "        if (episode + 1) % 100 == 0:\n",
        "            avg_reward = np.mean(rewards_per_episode[-100:])\n",
        "            print(f\"Episodio {episode+1:3d}/{episodes} | Recompensa promedio: {avg_reward:7.2f}\")\n",
        "    \n",
        "    return Q, rewards_per_episode, episode_lengths\n",
        "\nprint(\"Entrenando Q-Learning con UCB...\\n\")\nenv_frozen = gym.make(\"FrozenLake-v1\")\nQ_ucb, rewards_ucb, lengths_ucb = ucb_q_learning(env_frozen, episodes=500, c=1.5)\n\nprint(\"\\n✓ UCB completado\")"
      ],
      "metadata": {
        "id": "cell_ucb_qlearn"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def thompson_sampling_q_learning(env, episodes=500, alpha=0.1, gamma=0.99):\n",
        "    \"\"\"\n",
        "    Thompson Sampling: Probabilistic exploration\n",
        "    Mantiene distribuciones sobre los valores Q\n",
        "    \"\"\"\n",
        "    # Para simplificar, usaremos Beta distributions\n",
        "    Q_mean = np.zeros((env.observation_space.n, env.action_space.n))\n",
        "    Q_var = np.ones((env.observation_space.n, env.action_space.n)) * 10  # Varianza inicial\n",
        "    rewards_per_episode = []\n",
        "    episode_lengths = []\n",
        "    \n",
        "    for episode in range(episodes):\n",
        "        state, _ = env.reset()\n",
        "        episode_reward = 0\n",
        "        steps = 0\n",
        "        terminated = False\n",
        "        \n",
        "        while not terminated:\n",
        "            # Thompson Sampling: sample from posterior\n",
        "            sampled_Q = np.random.normal(Q_mean[state, :], np.sqrt(Q_var[state, :]))\n",
        "            action = np.argmax(sampled_Q)\n",
        "            \n",
        "            # Ejecutar acción\n",
        "            next_state, reward, terminated, truncated, info = env.step(action)\n",
        "            episode_reward += reward\n",
        "            \n",
        "            # Actualizar mean y varianza\n",
        "            td_error = reward + gamma * np.max(Q_mean[next_state, :]) - Q_mean[state, action]\n",
        "            Q_mean[state, action] += alpha * td_error\n",
        "            Q_var[state, action] = max(0.1, Q_var[state, action] * 0.99)  # Reducir incertidumbre\n",
        "            \n",
        "            state = next_state\n",
        "            steps += 1\n",
        "        \n",
        "        rewards_per_episode.append(episode_reward)\n",
        "        episode_lengths.append(steps)\n",
        "        \n",
        "        if (episode + 1) % 100 == 0:\n",
        "            avg_reward = np.mean(rewards_per_episode[-100:])\n",
        "            print(f\"Episodio {episode+1:3d}/{episodes} | Recompensa promedio: {avg_reward:7.2f}\")\n",
        "    \n",
        "    return Q_mean, rewards_per_episode, episode_lengths\n",
        "\nprint(\"\\nEntrenando Q-Learning con Thompson Sampling...\\n\")\nenv_frozen = gym.make(\"FrozenLake-v1\")\nQ_ts, rewards_ts, lengths_ts = thompson_sampling_q_learning(env_frozen, episodes=500)\n\nprint(\"\\n✓ Thompson Sampling completado\")"
      ],
