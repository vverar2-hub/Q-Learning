      "source": [
        "## 1.2 Q-Learning en CliffWalking"
      ],
      "metadata": {
        "id": "section_qlearning_cliff"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def q_learning_cliff(env, episodes=500, alpha=0.1, gamma=0.99, epsilon_start=1.0, epsilon_end=0.01, epsilon_decay=0.995):\n",
        "    \"\"\"\n",
        "    Q-Learning con Epsilon-Greedy para CliffWalking\n",
        "    \"\"\"\n",
        "    Q = np.zeros((env.observation_space.n, env.action_space.n))\n",
        "    rewards_per_episode = []\n",
        "    episode_lengths = []\n",
        "    epsilon = epsilon_start\n",
        "    \n",
        "    for episode in range(episodes):\n",
        "        state, _ = env.reset()\n",
        "        episode_reward = 0\n",
        "        steps = 0\n",
        "        terminated = False\n",
        "        \n",
        "        while not terminated:\n",
        "            # Epsilon-Greedy\n",
        "            if np.random.random() < epsilon:\n",
        "                action = env.action_space.sample()\n",
        "            else:\n",
        "                action = np.argmax(Q[state, :])\n",
        "            \n",
        "            # Ejecutar acción\n",
        "            next_state, reward, terminated, truncated, info = env.step(action)\n",
        "            episode_reward += reward\n",
        "            \n",
        "            # Actualizar Q\n",
        "            Q[state, action] += alpha * (reward + gamma * np.max(Q[next_state, :]) - Q[state, action])\n",
        "            \n",
        "            state = next_state\n",
        "            steps += 1\n",
        "        \n",
        "        rewards_per_episode.append(episode_reward)\n",
        "        episode_lengths.append(steps)\n",
        "        \n",
        "        # Decaer epsilon\n",
        "        epsilon = max(epsilon_end, epsilon * epsilon_decay)\n",
        "        \n",
        "        if (episode + 1) % 100 == 0:\n",
        "            avg_reward = np.mean(rewards_per_episode[-100:])\n",
        "            print(f\"Episodio {episode+1:3d}/{episodes} | Recompensa promedio: {avg_reward:7.2f} | Epsilon: {epsilon:.4f}\")\n",
        "    \n",
        "    return Q, rewards_per_episode, episode_lengths\n",
        "\n",
        "print(\"\\nEntrenando Q-Learning en CliffWalking...\\n\")\nenv_cliff = gym.make(\"CliffWalking-v0\")\nQ_cliff, rewards_cliff, lengths_cliff = q_learning_cliff(env_cliff, episodes=500)\n\nprint(\"\\n✓ Entrenamiento completado\")"
      ],
      "metadata": {
        "id": "cell_train_cliff"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Visualizar resultados\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
