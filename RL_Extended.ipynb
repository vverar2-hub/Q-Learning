        "\n",
        "# Longitud de episodios\nsmoothed_lengths = np.convolve(lengths_cliff, np.ones(window)/window, mode='valid')\naxes[1].plot(smoothed_lengths, 'r-', linewidth=2)\naxes[1].set_xlabel('Episodio', fontsize=12)\naxes[1].set_ylabel('Pasos por Episodio', fontsize=12)\naxes[1].set_title('Q-Learning en CliffWalking: Longitud de Episodios', fontsize=13, fontweight='bold')\naxes[1].grid(True, alpha=0.3)\n",
        "\nplt.tight_layout()\nplt.show()\n",
        "\nprint(f\"\\nRecompensa promedio final (últimos 50 episodios): {np.mean(rewards_cliff[-50:]):.2f}\")\nprint(f\"Longitud promedio final (últimos 50 episodios): {np.mean(lengths_cliff[-50:]):.1f} pasos\")"
      ],
      "metadata": {
        "id": "cell_plot_cliff"
      },
      "execution_count": null,
      "outputs": []
